# ==============================================================================
# AgentPhased Environment Configuration Template
# ==============================================================================
# Copy this file to .env and adjust the values for your environment.
# DO NOT commit your actual .env file to version control.

# ------------------------------------------------------------------------------
# Dashboard / Frontend (Vite)
# ------------------------------------------------------------------------------

# The URL of the AgentPhased backend API.
# The dashboard uses this to route API requests (and SSE streams) to the server.
VITE_API_URL=http://127.0.0.1:8000


# ------------------------------------------------------------------------------
# Backend Server (FastAPI / Uvicorn)
# ------------------------------------------------------------------------------

# The host interface to bind the API server to.
# Use 127.0.0.1 for local only, or 0.0.0.0 to expose to the network.
AGENTPHASED_HOST=127.0.0.1

# The port on which the backend server will listen.
AGENTPHASED_PORT=8000

# (Optional) Secret key used if JWT sessions or other signed tokens are added later.
# AGENTPHASED_SECRET_KEY=replace_with_a_long_random_string


# ------------------------------------------------------------------------------
# AgentMem (Rust Core / RocksDB / ONNX)
# ------------------------------------------------------------------------------

# Control the log level of the underlying Rust core.
# Valid values: error, warn, info, debug, trace
RUST_LOG=info

# (Optional) Explicitly set ONNX execution providers.
# Valid examples: CPUExecutionProvider, CUDAExecutionProvider, CoreMLExecutionProvider
# ONNX_PROVIDERS=CPUExecutionProvider

# The directory where AgentPhased stores identity keys and RocksDB memory.
# If unset, defaults to ~/.agentid or a local temporary directory depending on usage.
# AGENTPHASED_DATA_DIR=/path/to/persistent/storage


# ------------------------------------------------------------------------------
# Third-Party Integrations (Optional)
# ------------------------------------------------------------------------------

# Add any required API keys for tools your agents will call.
# OPENAI_API_KEY=sk_test_...
# STRIPE_API_KEY=sk_test_...
